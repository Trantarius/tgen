[gd_scene load_steps=3 format=3 uid="uid://6fdasijlu653"]

[ext_resource type="Texture2D" uid="uid://flviegdv5c4l" path="res://interface/arrow_right.png" id="2_cot1p"]

[sub_resource type="GDScript" id="GDScript_pug4x"]
script/source = "@tool
extends VBoxContainer

@export var title:String:
	get:
		if(has_node(\"HBoxContainer/Button\")):
			return $HBoxContainer/Button.text
		return \"\"
	set(to):
		if(has_node(\"HBoxContainer/Button\")):
			$HBoxContainer/Button.text = to

@export var expanded:bool:
	get:
		if(has_node(\"HBoxContainer/Button\")):
			return $HBoxContainer/Button.button_pressed
		return false
	set(to):
		if(has_node(\"HBoxContainer/Button\")):
			$HBoxContainer/Button.button_pressed = to
			_on_button_toggled(to)

@onready var expand_button:Button = $HBoxContainer/Button


func _ready() -> void:
	_on_button_toggled(expand_button.button_pressed)

func _on_button_toggled(toggled_on: bool) -> void:
	if(toggled_on):
		expand_button.icon = preload(\"res://interface/arrow_down.png\")
	else:
		expand_button.icon = preload(\"res://interface/arrow_right.png\")
	for child in get_children():
		if(child.owner!=self):
			child.visible = toggled_on
"

[node name="Expandable" type="VBoxContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = SubResource("GDScript_pug4x")
title = "Expandable"

[node name="HBoxContainer" type="HBoxContainer" parent="."]
layout_mode = 2

[node name="Button" type="Button" parent="HBoxContainer"]
layout_mode = 2
toggle_mode = true
text = "Expandable"
icon = ExtResource("2_cot1p")
flat = true
alignment = 0

[connection signal="toggled" from="HBoxContainer/Button" to="." method="_on_button_toggled"]
